ENDIF;

M5 0.2498 Q1*SC Q1H*SC 0 -0.0032*(Q1/-0.40033)*SC 0 0.055;  {Q1+Hex}

IF (MISALIGN=1);
 SA -0.000051 -0.000145; {x, y}
