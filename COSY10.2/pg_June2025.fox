{after WF modif.}
FC 1 1 2  -0.124 1.98 0.186 -0.069 0.01 0.053;{entr, elect dipole}
FC 1 1 2  -0.124 1.98 0.186 -0.069 0.01 0.053;{entr, elect dipole}

{Fernando introduced artificial misalignments to WF2 to "correct"
for the deviations caused by Q9's 0.8mm misalignment}

IF (WF2ON=1);
IF (MISALIGN=1);
 TA -0.1 -0.1; {Yaw, Pitch}
 {RA 10.1; {Roll}}
 {SA 0.001 0.001; {x, y}}
ENDIF;

CB;
WC WF2R WF2R 2.365  0.11 NE2 NM1 4 ;                       {WF2}
CB;

IF (MISALIGN=1);
 TA 0.1 0.1; {Yaw, Pitch}
 {RA -10.1; {Roll}}
 {SA -0.001 -0.001; {x, y}}
ENDIF;
ELSEIF 1=1;
DL 2.365;                                                  {WF2 OFF}
ENDIF;
FD;
FR 3;

WMI;

DL 4.644225559; {DL29, Do. WF2 - SLH_VD1783 (Only separated by a small distance)}
WMI;

{-----------------------------------------------------------------------------------------}
{FOCAL PLANE 3 - LOCATION OF SLH 1783, VD 1783 (4.65" X 5.236"), FC 1798 (1.587" X 1.423")}
{-----------------------------------------------------------------------------------------}

{WW(1):= VMAX(RAY(1));
WW(2):= VMIN(RAY(1));}
{WRITE 6 'FP3Xdim' WW(1)-WW(2);}
{WV:=(WW(1)-WW(2));}
{WRITE 6 'FP3Xdim' WV;}
{MRESOL_P1 := ABS(ME(1,7))/(2*XX*ME(1,1));}
{WRITE 6 'Mass Res.Power at FP3 ='&S(MRESOL_P1);}
{WRITE 6 'FP3Res ='&S((ABS(ME(1,7))/(WV)));}
{WRITE 6 'M11=XX, M12=XY, M16=XE, M26=YE, M17=XM =>' ME(1,1) ME(1,2) ME(1,6) ME(2,6) ME(1,7);}

DL 0.208449441; {DL30, VD1783 - Up. Q12}
WMI;

{***** Section 4 *****}

IF (MISALIGN=1);
 TA -0.0156 0.0091; {Yaw, Pitch}
 RA -0.0055; {Roll}
 SA 0.000282 -0.000196; {x, y}
ENDIF;

MQ 0.2977 Q12*SC 0.07;                                     {Q12}

IF (MISALIGN=1);
 SA -0.000282 0.000196; {x, y}
 RA 0.0055; {Roll}
 TA 0.0156 -0.0091; {Yaw, Pitch}
ENDIF;

WMI;

DL 0.350425; {DL31}
WMI;

IF (MISALIGN=1);
 TA 0.0321 -0.0380; {Yaw, Pitch}
 RA 0.0271; {Roll}
 SA 0.000301 -0.000191; {x, y}
ENDIF;

MQ 0.3008 Q13*SC 0.05;                                     {Q13}

IF (MISALIGN=1);
 SA -0.000301 0.000191; {x, y}
 RA -0.0271; {Roll}
 TA -0.0321 0.0380; {Yaw, Pitch}
ENDIF;

WMI;

DL 0.659564; {DL32}
WMI;

IF (MISALIGN=1);
 TA 0.0122 -0.0015; {Yaw, Pitch}
 RA -0.0031; {Roll}
 SA 0.000292 -0.000482; {x, y}
ENDIF;

MC 1.25 55. 0.03 B1N B7S1 B7S2 4;                          {B7}

IF (MISALIGN=1);
 SA -0.000292 0.000482; {x, y}
 RA 0.0031; {Roll}
 TA -0.0122 0.0015; {Yaw, Pitch}
ENDIF;

WMI;

DL 0.680262; {DL33}
WMI;

IF (MISALIGN=1);
 TA 0.0048 0.0004; {Yaw, Pitch}
 RA -0.0002; {Roll}
 SA -0.000214 -0.000520; {x, y}
ENDIF;

MC 1.25 55. 0.03 B1N B8S1 B8S2 4;                          {B8}

IF (MISALIGN=1);
 SA 0.000214 0.000520; {x, y}
 RA 0.0002; {Roll}
 TA -0.0048 -0.0004; {Yaw, Pitch}
ENDIF;

WMI;

DL 0.389887068; {To VD 1836 (SIZE?)}
WMI;

DL 0.469972932; {Remainder of DL34}
WMI;

IF (MISALIGN=1);
 TA 0.0167 -0.0073; {Yaw, Pitch}
 RA 0.0073; {Roll}
 SA -0.000269 -0.000371; {x, y}
ENDIF;

MQ 0.2995 Q14*SC 0.05;                                     {Q14}

IF (MISALIGN=1);
 SA 0.000269 0.000371; {x, y}
 RA -0.0073; {Roll}
 TA -0.0167 0.0073; {Yaw, Pitch}
ENDIF;

WMI;

DL 0.449858; {DL35}
WMI;

IF (MISALIGN=1);
 TA -0.0232 0.0149; {Yaw, Pitch}
 RA -0.0214; {Roll}
 SA -0.000262 -0.000540; {x, y}
ENDIF;

MQ 0.3012 Q15*SC 0.05;                                     {Q15}

IF (MISALIGN=1);
 SA 0.000262 0.000540; {x, y}
 RA 0.0214; {Roll}
 TA 0.0232 -0.0149; {Yaw, Pitch}
ENDIF;

WMI;

DL 0.7112; {Do. Q15 - UMCP}
WMI;

DL 1.397508; {UMCP - DMCP}
WMI;

DL 0.512209509; {UMCP - SLH1879}
WMI;

DL 0.208469264; {SLH1879 - VD1879}
WMI;

DL 0.3302; {VD1879 - DSSD}
WMI;

{WW(1):= VMAX(RAY(1));
WW(2):= VMIN(RAY(1));
WVX:=(WW(1)-WW(2))*(WW(1)-WW(2));
WW(1):= VMAX(RAY(3));
WW(2):= VMIN(RAY(3));
WVY:=(WW(1)-WW(2))*(WW(1)-WW(2));}
{WRITE 6 'BeamSpotSize'&S((WVX+WVY));}

ENDPROCEDURE;

{##############################################################}
{############## DEFINITION AND COMMAND ########################}
{##############################################################}
OV 4 3 2 ;
{OV 1 3 2 ;}

WSET 1.5E-3; {REQUIRED TO MINIMIZE ERROR IN WF INTEGRATION}
SETEFB; {SET THE DIPOLES EFB's and WF E- and B-FIELDS INHOMOGENEITIES}

{******************************************}
{YOU DEFINE THE INITIAL RAY PARAMETERS HERE}
XX:=0.00075;
YY:=0.00075;
AX:=0.025;
AY:=0.025;
DE:= 0.031;
{******************************************}

NMAX:=189;

{SET MAGNETS}
Q1_SC:= 1.0;
Q2_SC:= 1.0;
Q3_SC:= 1.0;
Q4_SC:= 1.0;
Q5_SC:= 1.0;
Q6_SC:= 1.0;
Q7_SC:= 0.981;
Q8_SC:= 1.0;
Q9_SC:= 1.0;
Q10_SC:= 1.0;
Q11_SC:= 0.985;
Q12_SC:= 0.97;
Q13_SC:= 0.86;
Q14_SC:= 1.327; {1.327;} {1.03 x1.289 phenomenological}
Q15_SC:= 1.241; {1.241;} {0.96 x1.293 phenomenological}
H1_SC:= 1.02;
H2_SC:= 1.0;
H3_SC:= 1.0;
O1_SC:= 1.0;

{THIS IS WHERE YOU CHANGE YOU CONFIGURATION}
WF1R:=7.0; {define the bending radius in WF1}
WF2R:=7.0; {define the bending radius in WF2 -- not important here because it is off}
WF1ON:=1; {WF2ON 0=OFF or 1=ON - CURRENTLY WF2 IS OFF}
WF2ON:=1; {WF2ON 0=OFF or 1=ON - CURRENTLY WF2 IS OFF}
MISALIGN:=1; {ACCOUNT =1 or not =0 for the measured misalignment}
OCT1ON:=1; {is octupole 1 ON=1 or OFF=0}

MATRIXINDEX := 250; {See page 53 of programmer's manual - need to avoid hitting already set units like -12 for making pdfs}

{*****(p,g) from Berg optics*****}
Q1:=-0.39773*Q1_SC;
Q1H:=0.004679;
Q2:=0.219352*Q2_SC;
H1:=0.0103065*H1_SC;
Q3:=0.242872*Q3_SC;
Q4:=-0.24756*Q4_SC;
Q5:=0.112391*Q5_SC;
H2:=0.010507*H2_SC;
Q6:=0.181632*Q6_SC;
Q7:=-0.030022*Q7_SC;
H3:=-0.0083745*H3_SC;
O1:=0.031283*O1_SC;
Q8:=-0.14822*Q8_SC;
Q9:=0.234380*Q9_SC;
Q10:=-0.03367*Q10_SC;
Q11:=0.161580*Q11_SC;
Q12:=-0.182*Q12_SC;
Q13:=0.1910*Q13_SC;
Q14:=0.12900*Q14_SC;
Q15:=-0.1380*Q15_SC; {If beam is 66 Selenium, field at pole tip}

{ALL THE MAGNETIC FIELD WILL BE SCALED TO THE RIGIDITY DEFINED IN THE TWO LINES BELOW}
{DON'T TOUCH THE NEXT TWO LINES!!!}
RP 206 66*PARA(1) 21*PARA(2) ; {Rigidity of 66 Selenium}
CANONICAL_RIGIDITY:=CONS(CHIM);

{******************************************}
{SET YOUR RECOIL OR BEAM HERE}
{RP 8.9566031061 19.9886*PARA(1) 7*PARA(2);}
{******************************************}

{DON'T TOUCH THE NEXT LINE!!!}
SC:=CONS(CHIM)/CANONICAL_RIGIDITY;

UM;
CR {Clears all rays}; UM;

{N1=1 {# of rays: 3} -> -1 0 +1}
{N1=2 {# of rays: 5} -> -2 -1 0 +1 +2}
{N1=3 {# of rays: 7} -> -3 -2 -1 0 +1 +2 +3}
{N1=4 {# of rays: 9} -> -4 -3 -2 -1 0 +1 +2 +3 +4}

N1:=1;N2:=3;N3:=1;N4:=1;N5:=2;

LOOP NX 1 2*N1+1;LOOP NA 1 2*N2+1;LOOP NY 1 2*N3+1;LOOP NB 1 2*N4+1;
LOOP NE 1 2*N5+1;

SRXX:= XX*(NX-(N1+1))/N1;
SRAX:= AX*(NA-(N2+1))/N2;
SRYY:= YY*(NY-(N3+1))/N3;
SRAY:= AY*(NB-(N4+1))/N4;
SRDE:= DE*(NE-(N5+1))/N5;

IF (((NA-(N2+1))/N2)^2+((NB-(N4+1))/N4)^2+((NE-(N5+1))/N5)^2)<1.01;
SR SRXX SRAX SRYY SRAY 0 SRDE 0 0 1;
ENDIF;
ENDLOOP;ENDLOOP;ENDLOOP;ENDLOOP;ENDLOOP;

{Test ray - Modify and/or add more for testing}
{Available Colors: 1=black, 2=blue, 3=red, 4=yellow, 5=green}
{6=yellowish green, 7=cyan, 8=magenta, 9=navy, 10=white/backgrnd}
{SR XX AX YY AY DL DE DM DZ Color;}

{SR 0 0 0 0 0 0 0 0 3;       {Fragment of interest (central ray), Red}
SR 0 0 0 0 0 0 (1/350) 0 6; {Relative mass dm/m = 1/350}
SR 0 0 0 0 0 -0.1 0 0 8; {Relative energy dE/E}
SR -0.005 0 0 0 0 0 0 0 3; }

BP;
RECOIL_BL;
EP;

PG -12 -12;

{WW(1):= VMAX(RAY(1));
WW(2):= VMIN(RAY(1));
WV:=(WW(1)-WW(2));
CENTER := (WW(1)+WW(2))/2;
WRITE 6 'VMAX_SIZE ='&S(WW(1));
WRITE 6 'VMIN_SIZE ='&S(WW(2));
WRITE 6 'Image size ='&S(WV);
WRITE 6 'Image Center is at'&S(CENTER);
WRITE 6 'Resolution by max ray at FP4 ='&S(ABS(ME(1,7))/(WV));
WRITE 6 'M11=XX, M12=XY, M16=XE, M26=YE, M17=XM =>' ME(1,1) ME(1,2) ME(1,6) ME(2,6) ME(1,7);
WRITE 6 'M11*M22 ='&S(ME(1,1)*ME(2,2));}

ENDPROCEDURE ;
RUN ;
END ;
