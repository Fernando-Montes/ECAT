{**************** WRITE MATRIX TO FILE WIHT AUTOMATIC INDEXING **************}

{NOTE: Experiment more with PM vs WM!}

PROCEDURE WMI;
WM MATRIXINDEX;                   {Create a fort.'MATRIXINDEX' file which contains the corresponding transformation matrix}
{RAYINDEX :=  MATRIXINDEX + 100;
WRAY RAYINDEX;                    {Create a fort.'RAYINDEX' file which contains the 8 coordinates for each ray at that point}  }
MATRIXINDEX := MATRIXINDEX + 1;
UM;                             {Clear it for the next element}
ENDPROCEDURE;

{**************** READ_RAY **************}
PROCEDURE READ_RAY;

VARIABLE SAVEMAP 10000 8;
SM SAVEMAP;
UM; CR;

{N1=1 {# of rays: 3} -> -1 0 +1}
{N1=2 {# of rays: 5} -> -2 -1 0 +1 +2}
{N1=3 {# of rays: 7} -> -3 -2 -1 0 +1 +2 +3}
{N1=4 {# of rays: 9} -> -4 -3 -2 -1 0 +1 +2 +3 +4}

N1:=1; N2:=3; N3:=1; N4:=1; N5:=2;

LOOP NX 1 2*N1+1;LOOP NA 1 2*N2+1;LOOP NY 1 2*N3+1;LOOP NB 1 2*N4+1;
LOOP NE 1 2*N5+1;

SRXX:= XX*(NX-(N1+1))/N1;
SRAX:= AX*(NA-(N2+1))/N2;
SRYY:= YY*(NY-(N3+1))/N3;
SRAY:= AY*(NB-(N4+1))/N4;
SRDE:= DE*(NE-(N5+1))/N5;

IF (((NA-(N2+1))/N2)^2+((NB-(N4+1))/N4)^2+((NE-(N5+1))/N5)^2)<1.01;
SR SRXX SRAX SRYY SRAY 0 SRDE 0 0 1;
ENDIF;
ENDLOOP;ENDLOOP;ENDLOOP;ENDLOOP;ENDLOOP;

AM SAVEMAP;
ENDPROCEDURE;

PROCEDURE PRINT_XDIM;

WW(1):= VMAX(RAY(1));
WW(2):= VMIN(RAY(1));
WRITE 6 'Xdim' WW(1)-WW(2);

ENDPROCEDURE;

PROCEDURE PRINT_YDIM;

WW(1):= VMAX(RAY(3));
WW(2):= VMIN(RAY(3));
WRITE 6 'Ydim' WW(1)-WW(2);

ENDPROCEDURE;


{**************** RECOIL_LINE ****************}

PROCEDURE RECOIL_BL;

